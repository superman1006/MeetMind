# ===== LLM API (OpenAI-compatible, e.g. Xiaomi MiMo) =====
API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASE_URL=https://api.your-llm-provider.com/v1
MODEL_NAME=mimo-xxxxx

# ===== Model Parameters =====
MAX_TOKENS=2000
TEMPERATURE=0.4

# ===== Seed Source (输入) =====
SEED_DATA_PATH=./data/seed

# ===== Elasticsearch (存储 + BM25 + 向量检索, 三合一) =====
# 用 docker-compose.yml 起的本地单节点 ES；走 https 时填 https://...，并把 ES_VERIFY_CERTS=false
ES_URL=http://localhost:9200
ES_API_KEY=
ES_INDEX_PREFIX=meetmind

# ===== Embedding (sentence-transformers, 本地, 384 维) =====
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# 模型缓存目录；默认放项目内 ./models/。如果想用全局 HF 缓存可改成 ~/.cache/huggingface/hub
EMBEDDING_CACHE_DIR=./models

# ===== Cohere Rerank (最终重排序) =====
COHERE_API_KEY=YOUR_COHERE_KEY
COHERE_RERANK_MODEL=rerank-v4.0-pro

# ===== 混合检索参数 =====
RETRIEVE_TOP_N=20    # ES BM25 + kNN 各自捞这么多候选, 合并去重后送 rerank
RERANK_TOP_N=5       # Cohere rerank 后给 LLM 的最终上下文条数

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Runtime Limits =====
MAX_ITERATIONS=15

# ===== LangSmith（可选，全链路追踪） =====
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=meetmind
