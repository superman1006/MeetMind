# ===== LLM API (OpenAI-compatible, e.g. Xiaomi MiMo) =====
API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASE_URL=https://api.your-llm-provider.com/v1
MODEL_NAME=mimo-xxxxx

# ===== Model Parameters =====
MAX_TOKENS=2000
TEMPERATURE=0.4

# ===== Database =====
CHROMA_BASE_PATH=./chroma_data
SEED_DATA_PATH=./data/seed

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Runtime Limits =====
MAX_ITERATIONS=15
RAG_TOP_K=3
