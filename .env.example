# ===== LLM API (OpenAI-compatible, e.g. Xiaomi MiMo) =====
API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASE_URL=https://api.your-llm-provider.com/v1
MODEL_NAME=mimo-xxxxx

# ===== Model Parameters =====
MAX_TOKENS=2000
TEMPERATURE=0.4

# ===== Seed Source (输入) =====
SEED_DATA_PATH=./data/seed

# ===== PostgreSQL (存储 + pgvector 向量检索 + pg_trgm 关键字召回, 三合一) =====
# 用 docker-compose.yml 起的本地单节点 PostgreSQL（pgvector/pgvector 镜像，含 vector 扩展）
# 连接串格式: postgresql://user:password@host:5432/dbname
# 注意: 宿主机 5432 若被本地原生 postgres 占用, docker-compose 已把容器映射到 5433
PG_URL=postgresql://meetmind:meetmind@localhost:5433/meetmind
# 每个 agent 一张表，表名 <prefix>_<agent>，如 meetmind_architect
PG_TABLE_PREFIX=meetmind

# ===== Embedding (sentence-transformers, 本地, 384 维) =====
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# 模型缓存目录；默认放项目内 ./models/。如果想用全局 HF 缓存可改成 ~/.cache/huggingface/hub
EMBEDDING_CACHE_DIR=./models

# ===== 本地 Rerank (cross-encoder, 最终重排序; 走 @huggingface/transformers, 无需 API key) =====
# 默认多语言 cross-encoder, 中文效果好; 模型缓存复用上面的 EMBEDDING_CACHE_DIR
RERANK_MODEL_NAME=Xenova/bge-reranker-base
# ONNX 量化精度: q8 体积小(~280MB)且分数对量化不敏感; 要更准可设 fp32
RERANK_DTYPE=q8

# ===== 混合检索参数 =====
RETRIEVE_TOP_N=20    # 关键字(pg_trgm) + kNN(pgvector) 各自捞这么多候选, 合并去重后送 rerank
RERANK_TOP_N=5       # rerank 后给 LLM 的最终上下文条数

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Runtime Limits =====
MAX_ITERATIONS=15

# ===== LangSmith（可选，全链路追踪） =====
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=meetmind
